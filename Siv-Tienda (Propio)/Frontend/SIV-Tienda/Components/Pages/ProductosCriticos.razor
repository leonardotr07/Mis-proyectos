@page "/productos-criticos"
@using SIV_Tienda.Services
@inject ProductoClient ProductoClient
@inject NavigationManager Navigation

<h1>Productos con Stock Crítico</h1>

<a href="/" class="btn btn-secondary mb-3">← Volver</a>

@if (productos == null)
{
    <p>Cargando...</p>
}
else if (!productos.Any())
{
    <div class="alert alert-success">No hay productos con stock crítico.</div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Categoría</th>
                <th>Precio</th>
                <th>Stock Actual</th>
                <th>Stock Mínimo</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in productos)
            {
                <tr>
                    <td>@p.Id</td>
                    <td>@p.Nombre</td>
                    <td>@p.Categoria</td>
                    <td>@p.Precio.Monto.ToString("C")</td>
                    <td class="text-danger fw-bold">@p.Stock.Valor</td>
                    <td>@p.StockMinimo.Valor</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private ICollection<Producto>? productos;

    protected override async Task OnInitializedAsync()
    {
        productos = await ProductoClient.ObtenerProductosCriticosAsync();
    }
}