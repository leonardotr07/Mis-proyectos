@page "/crear-producto"
@using SIV_Tienda.Services
@inject ProductoClient ProductoClient
@inject NavigationManager Navigation

<h1>Registrar Nuevo Producto</h1>

<EditForm Model="@nuevoProducto" OnValidSubmit="@HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger mb-3" />

    <div class="mb-3">
        <label for="nombre" class="form-label">Nombre del Producto *</label>
        <input type="text" id="nombre" class="form-control" @bind="nuevoProducto.Nombre" />
        <ValidationMessage For="@(() => nuevoProducto.Nombre)" />
    </div>

    <div class="mb-3">
        <label for="descripcion" class="form-label">Descripción</label>
        <input type="text" id="descripcion" class="form-control" @bind="nuevoProducto.Descripcion" />
        <ValidationMessage For="@(() => nuevoProducto.Descripcion)" />
    </div>

    <div class="mb-3">
        <label for="categoria" class="form-label">Categoría *</label>
        <select id="categoria" class="form-select" @bind="nuevoProducto.Categoria">
            <option value="">-- Seleccionar --</option>
            @foreach (var cat in Enum.GetValues<RegistrarProductoComandoCategoria>())
            {
                <option value="@cat">@cat</option>
            }
        </select>
        <ValidationMessage For="@(() => nuevoProducto.Categoria)" />
    </div>

    <div class="mb-3">
        <label for="precio" class="form-label">Precio (S/) *</label>
        <input type="number" id="precio" class="form-control" step="0.01" @bind="nuevoProducto.Precio" />
        <ValidationMessage For="@(() => nuevoProducto.Precio)" />
    </div>

    <div class="mb-3">
        <label for="stock" class="form-label">Stock Inicial *</label>
        <input type="number" id="stock" class="form-control" step="1" @bind="nuevoProducto.Stock" />
        <ValidationMessage For="@(() => nuevoProducto.Stock)" />
    </div>

    <div class="mb-3">
        <label for="stockMinimo" class="form-label">Stock Mínimo *</label>
        <input type="number" id="stockMinimo" class="form-control" step="1" @bind="nuevoProducto.StockMinimo" />
        <ValidationMessage For="@(() => nuevoProducto.StockMinimo)" />
    </div>

    <button type="submit" class="btn btn-primary" disabled="@enviando">
        @(enviando ? "Registrando..." : "Registrar Producto")
    </button>
    <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
</EditForm>

@if (mensajeError != null)
{
    <div class="alert alert-danger mt-3">@mensajeError</div>
}

@* Modal de detalle *@
<ProductoDetalleModal Visible="@mostrarModal" 
                      Titulo="Producto Registrado Exitosamente"
                      Producto="@productoCreado"
                      OnClose="CerrarModal" />

@code {
    private RegistrarProductoComando nuevoProducto = new();
    private string? mensajeError;
    private bool enviando = false;

    private bool mostrarModal = false;
    private Producto? productoCreado;

    private bool ValidarStock()
    {
        if (nuevoProducto.StockMinimo > nuevoProducto.Stock)
        {
            mensajeError = "El stock mínimo no puede ser mayor al stock inicial.";
            return false;
        }
        return true;
    }

    private async Task HandleValidSubmit()
    {
        enviando = true;
        mensajeError = null;

        try
        {
            if (!ValidarStock())
                return;

            var resultado = await ProductoClient.RegistrarProductoAsync(nuevoProducto);
            productoCreado = resultado;
            mostrarModal = true;
            StateHasChanged();
            nuevoProducto = new RegistrarProductoComando(); // Limpia el formulario
        }
        catch (ApiException ex)
        {
            mensajeError = $"Error al registrar: {ex.Message}";
        }
        catch (Exception ex)
        {
            mensajeError = $"Error de conexión: {ex.Message}";
        }
        finally
        {
            enviando = false;
        }
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        Navigation.NavigateTo("/");
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/");
    }
}