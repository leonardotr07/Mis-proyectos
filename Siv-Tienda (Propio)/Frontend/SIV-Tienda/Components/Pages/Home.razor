@page "/" 
@using SIV_Tienda.Services
@using SIV_Tienda.Components
@inject ProductoClient ProductoClient

@*Titulo de la página de productos*@
<h1>Lista de Productos</h1>

@* Alerta de productos con stock crítico *@
@if (productosCriticos != null && productosCriticos.Any())
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <strong>¡Atención!</strong> Hay <span class="badge bg-danger">@productosCriticos.Count</span> productos con stock crítico.
        <a href="/productos-criticos" class="alert-link">Ver todos</a>
    </div>
}

@*Botón con referencia a crear un nuevo producto*@
<a href="/crear-producto" class="btn btn-success mb-3">+ Nuevo Producto</a>


@*Listar productos*@
@if (productos == null)
{
    <p>Cargando...</p>
}
else if (!productos.Any())
{
    <p>No hay productos registrados.</p>
}
else
{
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Categoría</th>
                <th>Precio</th>
                <th>Stock</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in productos)
            {
                <tr>
                    <td>@p.Id</td>
                    <td>@p.Nombre</td>
                    <td>@p.Categoria</td>
                    <td>@p.Precio.Monto.ToString("C")</td>
                    <td>@p.Stock.Valor</td>
                    <td>
                        <a href="/editar-producto/@p.Id" class="btn btn-sm btn-primary">Editar</a>
                        <button type="button" class="btn btn-sm btn-danger" @onclick="() => PedirConfirmacion(p)">Eliminar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}


<ConfirmarEliminarModal Visible="@mostrarModalEliminar"
                        Producto="@productoAEliminar"
                        OnConfirm="ConfirmarEliminar"
                        OnCancel="CancelarEliminar" />

@code {
    private ICollection<Producto>? productos;
    private bool mostrarModalEliminar=false;

    private Producto? productoAEliminar;
     private ICollection<Producto>? productosCriticos;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        productos = await ProductoClient.ListarProductosAsync();
        productosCriticos = await ProductoClient.ObtenerProductosCriticosAsync();
    }

    private void PedirConfirmacion(Producto datProducto)
    {
        var nombre = productos?.FirstOrDefault(p => p.Id == datProducto.Id)?.Nombre ?? "producto";
        productoAEliminar = datProducto;
        mostrarModalEliminar = true;
        StateHasChanged();
    }

    private void CancelarEliminar()
    {
        mostrarModalEliminar = false;
        productoAEliminar = null;
    }

    private async Task ConfirmarEliminar()
    {
        if (productoAEliminar!=null)
        {
            try
            {
                await ProductoClient.EliminarProductoAsync(productoAEliminar.Id);
                productos = await ProductoClient.ListarProductosAsync();
                StateHasChanged();
            }
            catch (Exception ex)
            {
                // Manejo de errores
                Console.WriteLine($"Error al eliminar: {ex.Message}");
            }
        }
        mostrarModalEliminar = false;
        productoAEliminar = null;
    }
}