<?xml version="1.0" encoding="utf-8"?>
<xs:schema xmlns:tns="http://almacen.services.weardrop.pucp.edu.pe/" targetNamespace="http://almacen.services.weardrop.pucp.edu.pe/" version="1.0" xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <xs:element name="eliminarMovimientoAlmacen" type="tns:eliminarMovimientoAlmacen" />
  <xs:element name="eliminarMovimientoAlmacenResponse" type="tns:eliminarMovimientoAlmacenResponse" />
  <xs:element name="insertarMovAlmacen" type="tns:insertarMovAlmacen" />
  <xs:element name="insertarMovAlmacenResponse" type="tns:insertarMovAlmacenResponse" />
  <xs:element name="listarMovimientosActivos" type="tns:listarMovimientosActivos" />
  <xs:element name="listarMovimientosActivosResponse" type="tns:listarMovimientosActivosResponse" />
  <xs:element name="listarMovimientosPorAlmacen" type="tns:listarMovimientosPorAlmacen" />
  <xs:element name="listarMovimientosPorAlmacenResponse" type="tns:listarMovimientosPorAlmacenResponse" />
  <xs:element name="modificarMovimientoAlmacen" type="tns:modificarMovimientoAlmacen" />
  <xs:element name="modificarMovimientoAlmacenResponse" type="tns:modificarMovimientoAlmacenResponse" />
  <xs:element name="obtenerMovimientoPorId" type="tns:obtenerMovimientoPorId" />
  <xs:element name="obtenerMovimientoPorIdResponse" type="tns:obtenerMovimientoPorIdResponse" />
  <xs:complexType name="modificarMovimientoAlmacen">
    <xs:sequence>
      <xs:element minOccurs="0" name="datMovimiento" type="tns:movimientoAlmacen" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="movimientoAlmacen">
    <xs:sequence>
      <xs:element name="activo" type="xs:boolean" />
      <xs:element minOccurs="0" name="datAlmacen" type="tns:almacen" />
      <xs:element minOccurs="0" name="datUsuario" type="tns:cuentaUsuario" />
      <xs:element minOccurs="0" name="fecha" type="xs:dateTime" />
      <xs:element name="idMovimiento" type="xs:int" />
      <xs:element minOccurs="0" name="lugarDestino" type="xs:string" />
      <xs:element minOccurs="0" name="lugarOrigen" type="xs:string" />
      <xs:element minOccurs="0" name="tipo" type="tns:tipoMovimiento" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="almacen">
    <xs:sequence>
      <xs:element name="activo" type="xs:boolean" />
      <xs:element name="id" type="xs:int" />
      <xs:element name="idTienda" type="xs:int" />
      <xs:element minOccurs="0" name="nombre" type="xs:string" />
      <xs:element name="stock" type="xs:int" />
      <xs:element minOccurs="0" name="ubicacion" type="xs:string" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="cuentaUsuario">
    <xs:sequence>
      <xs:element name="activo" type="xs:boolean" />
      <xs:element minOccurs="0" name="contrasenha" type="xs:string" />
      <xs:element minOccurs="0" name="email" type="xs:string" />
      <xs:element minOccurs="0" name="empleado" type="tns:empleado" />
      <xs:element name="idCuenta" type="xs:int" />
      <xs:element minOccurs="0" name="tipo" type="tns:tipoCuenta" />
      <xs:element minOccurs="0" name="tokenExpiracion" type="xs:dateTime" />
      <xs:element minOccurs="0" name="tokenRecuperacion" type="xs:string" />
      <xs:element minOccurs="0" name="username" type="xs:string" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="empleado">
    <xs:complexContent mixed="false">
      <xs:extension base="tns:persona">
        <xs:sequence>
          <xs:element name="activo" type="xs:boolean" />
          <xs:element minOccurs="0" name="cargoAsignado" type="tns:cargo" />
          <xs:element name="idEmpleado" type="xs:int" />
          <xs:element name="sueldo" type="xs:double" />
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:complexType name="persona" abstract="true">
    <xs:sequence>
      <xs:element name="dni" type="xs:int" />
      <xs:element name="genero" type="xs:unsignedShort" />
      <xs:element name="idPersona" type="xs:int" />
      <xs:element minOccurs="0" name="nombre" type="xs:string" />
      <xs:element minOccurs="0" name="primerApellido" type="xs:string" />
      <xs:element minOccurs="0" name="segundoApellido" type="xs:string" />
      <xs:element name="telefono" type="xs:int" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="cargo">
    <xs:sequence>
      <xs:element name="abreviatura" type="xs:unsignedShort" />
      <xs:element name="activo" type="xs:boolean" />
      <xs:element minOccurs="0" name="descripcion" type="xs:string" />
      <xs:element name="idCargo" type="xs:int" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="tipoCuenta">
    <xs:sequence>
      <xs:element name="activo" type="xs:boolean" />
      <xs:element minOccurs="0" name="descripcion" type="xs:string" />
      <xs:element name="idTipoCuenta" type="xs:int" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="modificarMovimientoAlmacenResponse">
    <xs:sequence>
      <xs:element name="return" type="xs:int" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="obtenerMovimientoPorId">
    <xs:sequence>
      <xs:element name="idMovimiento" type="xs:int" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="obtenerMovimientoPorIdResponse">
    <xs:sequence>
      <xs:element minOccurs="0" name="return" type="tns:movimientoAlmacen" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="insertarMovAlmacen">
    <xs:sequence>
      <xs:element minOccurs="0" name="datMovimiento" type="tns:movimientoAlmacen" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="insertarMovAlmacenResponse">
    <xs:sequence>
      <xs:element name="return" type="xs:int" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="listarMovimientosPorAlmacen">
    <xs:sequence>
      <xs:element name="arg0" type="xs:int" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="listarMovimientosPorAlmacenResponse">
    <xs:sequence>
      <xs:element minOccurs="0" maxOccurs="unbounded" name="return" type="tns:movimientoAlmacen" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="eliminarMovimientoAlmacen">
    <xs:sequence>
      <xs:element name="idMovimiento" type="xs:int" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="eliminarMovimientoAlmacenResponse">
    <xs:sequence>
      <xs:element name="return" type="xs:int" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="listarMovimientosActivos">
    <xs:sequence />
  </xs:complexType>
  <xs:complexType name="listarMovimientosActivosResponse">
    <xs:sequence>
      <xs:element minOccurs="0" maxOccurs="unbounded" name="return" type="tns:movimientoAlmacen" />
    </xs:sequence>
  </xs:complexType>
  <xs:simpleType name="tipoMovimiento">
    <xs:restriction base="xs:string">
      <xs:enumeration value="Entrada" />
      <xs:enumeration value="Salida" />
      <xs:enumeration value="Mov_Interno" />
    </xs:restriction>
  </xs:simpleType>
</xs:schema>